rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

// ─── Helper function to check for admin role (CUSTOM CLAIMS) ───────────
function isAdmin() {
  return request.auth != null && request.auth.token.admin == true;
}

// ─── students collection ───────────────────────────────────────────────
match /students/{userId} {

  // Read: user can read own doc OR admin can read any
  allow read: if request.auth != null
    && (request.auth.uid == userId || isAdmin());

  // Create: user can create their own doc with restrictions
  allow create: if request.auth != null
    && request.auth.uid == userId
    && !('creatorCode' in request.resource.data)
    && (!('cashback' in request.resource.data) || request.resource.data.cashback == 0);

  // Update: user can update own doc but cannot modify restricted fields
  allow update: if request.auth != null
    && request.auth.uid == userId
    && !('creatorCode' in request.resource.data.diff(resource.data).affectedKeys())
    && !('cashback' in request.resource.data.diff(resource.data).affectedKeys());

  // Admin can write anything
  allow write: if isAdmin();
}

// ─── creator_codes collection ──────────────────────────────────────────
match /creator_codes/{code} {
  allow read: if request.auth != null && resource.data.uid == request.auth.uid;
  allow write: if false;
}

// ─── meta collection (cached vendor list, etc.) ────────────────────────
match /meta/{docId} {
  allow read: if isAdmin();
  allow write: if isAdmin();
}

// ─── cms collection ───────────────────────────────────────────────────
match /cms/{docId} {
  allow read: if true;
  allow write: if isAdmin();
}

// ─── categories collection ────────────────────────────────────────────
match /categories/{catId} {
  allow read: if request.auth != null;
  allow write: if isAdmin();
}

// ─── offers collection ────────────────────────────────────────────────
match /offers/{offerId} {
  allow read: if request.auth != null;
  allow write: if isAdmin();
}

// ─── vendors collection ───────────────────────────────────────────────
match /vendors/{vendorId} {
  allow read: if true;
  allow write: if isAdmin();
}

// ─── rewards collection ───────────────────────────────────────────────
match /rewards/{rewardId} {
  allow read: if true;
  allow write: if isAdmin();
}

// ─── transactions collection ──────────────────────────────────────────
match /transactions/{transactionId} {
  allow read: if request.auth != null
    && (resource.data.userId == request.auth.uid
      || resource.data.vendorId == request.auth.uid
      || isAdmin());

  allow create: if request.auth != null
    && request.resource.data.userId == request.auth.uid;

  allow write: if isAdmin();
}

// ─── notifications collection ─────────────────────────────────────────
match /notifications/{notificationId} {
  allow read: if request.auth != null;
  allow write: if isAdmin();
}

// ─── pushTokens collection ────────────────────────────────────────────
match /pushTokens/{tokenId} {
  allow read: if isAdmin();
  allow write: if false;
}

// ─── otps collection (admin SDK only) ──────────────────────────────────
match /otps/{email} {
  allow read, write: if false;
}

// ─── verification_requests collection ────────────────────────────────
match /verification_requests/{requestId} {
  allow read: if isAdmin();
  allow write: if false;
}

// ─── Default deny ─────────────────────────────────────────────────────
match /{document=**} {
  allow read, write: if false;
}
}
}
